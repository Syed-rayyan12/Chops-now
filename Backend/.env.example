# Backend environment variables example
# Use a real SendGrid API key in production. Do NOT commit real keys.
SENDGRID_API_KEY=your-sendgrid-api-key-here

# Fallback Gmail SMTP settings (optional if using SendGrid)
EMAIL_USER=your@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# Other env vars used by the backend
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
JWT_SECRET=your_jwt_secret

# Cloudflare R2 (S3-compatible object storage)
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=chopnow
R2_PUBLIC_URL=https://pub-your-account-id.r2.dev
